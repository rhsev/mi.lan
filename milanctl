#!/usr/bin/env ruby
# frozen_string_literal: true

require 'pathname'
require 'rbconfig'
require 'net/http'
require 'uri'
require 'fileutils'
require 'json'

# Find a Ruby >= 3 to run milan.rb, regardless of how milanctl was invoked.
# GUI apps (Bunch, Automator, LaunchAgent, …) get a stripped environment where
# version managers are not initialized, so the invoking Ruby may be the old
# macOS system Ruby. We search common locations before falling back.
def find_ruby
  return RbConfig.ruby if RUBY_VERSION.to_i >= 3

  candidates = [
    # rbenv (RBENV_ROOT override or default)
    File.join(ENV.fetch('RBENV_ROOT', File.expand_path('~/.rbenv')), 'shims', 'ruby'),
    # asdf
    File.expand_path('~/.asdf/shims/ruby'),
    # mise / rtx
    File.expand_path('~/.local/share/mise/shims/ruby'),
    File.expand_path('~/.mise/shims/ruby'),
    # Homebrew (Apple Silicon / Intel)
    '/opt/homebrew/bin/ruby',
    '/usr/local/bin/ruby',
  ]

  candidates.each do |path|
    next unless File.executable?(path)
    version_line = `"#{path}" --version 2>/dev/null`.strip
    major = version_line[/ruby (\d+)/, 1].to_i
    return path if major >= 3
  end

  warn "Warning: could not find Ruby >= 3; milan.rb may fail to start."
  RbConfig.ruby
end

# Paths and constants
MILAN_DIR   = Pathname.new(__FILE__).realpath.dirname
MILAN_PATH  = MILAN_DIR.join("milan.rb")
PID_FILE    = MILAN_DIR.join("milan.pid")
LOG_FILE    = MILAN_DIR.join("milan.log")

@dylan_url = ENV.fetch("DYLAN_URL", "http://dy.lan/whoami")

def check_identity
  if @dylan_url.to_s.empty?
    ENV["MILAN_IDENTITY"] ||= "standalone"
    return true
  end

  print "Checking identity with Dylan... "

  uri = URI(@dylan_url)
  response = Net::HTTP.start(uri.host, uri.port, open_timeout: 3, read_timeout: 3) do |http|
    http.get(uri.request_uri)
  end

  identity = response.body.strip

  if identity.start_with?("Error", "Unknown")
    puts "REJECTED\nDylan says: #{identity}"
    return false
  end

  puts "OK - I am #{identity}"
  ENV["MILAN_IDENTITY"] = identity.split(/\s+/).first
  true
rescue StandardError => e
  puts "FAILED (Dylan not reachable: #{e.message})"
  false
end

MILAN_PORT = 8080

def running?
  return false unless PID_FILE.exist?
  pid = PID_FILE.read.to_i
  Process.kill(0, pid)
  pid
rescue Errno::ESRCH, Errno::ENOENT
  false
end

# PIDs of any process bound to MILAN_PORT (may differ from PID file)
def port_pids
  pids = `lsof -ti:#{MILAN_PORT} 2>/dev/null`.strip.split("\n").map(&:to_i).reject(&:zero?)
  return pids unless pids.empty?
  # lsof misses long-running detached processes on macOS; fall back to pgrep
  return [] if port_free?
  `pgrep -f 'milan\\.rb' 2>/dev/null`.strip.split("\n").map(&:to_i).reject(&:zero?)
rescue
  []
end

def port_free?
  require 'socket'
  TCPServer.new('0.0.0.0', MILAN_PORT).close
  true
rescue Errno::EADDRINUSE
  false
end

# TERM then KILL anything still on the port
def clear_port
  pids = port_pids
  return if pids.empty?

  pids.each do |p|
    begin
      Process.kill("TERM", p)
    rescue Errno::EPERM
      owner = `ps -p #{p} -o user=`.strip
      puts "Cannot kill PID #{p} — owned by '#{owner}', not '#{`id -un`.strip}'"
      puts "  sudo kill -9 #{p}"
      return
    rescue Errno::ESRCH
      # already gone
    end
  end

  5.times { sleep 1; return if port_pids.empty? }
  port_pids.each { |p| Process.kill("KILL", p) rescue nil }
  10.times { sleep 0.2; return if port_pids.empty? }
end

def start
  if (pid = running?)
    puts "Milan already running (PID #{pid})"
    return
  end

  unless MILAN_PATH.exist?
    puts "Error: #{MILAN_PATH} not found. Cannot start."
    return
  end

  # Ensure port is free before spawning
  unless port_free?
    puts "Port #{MILAN_PORT} in use — clearing..."
    clear_port
    unless port_free?
      puts "Cannot free port #{MILAN_PORT}. Aborting."
      return
    end
  end

  return unless check_identity

  ruby_bin = find_ruby

  pid = spawn(ruby_bin, MILAN_PATH.to_s,
              chdir: MILAN_DIR.to_s,
              out: [LOG_FILE.to_s, "a"],
              err: [:child, :out],
              pgroup: true)

  Process.detach(pid)
  PID_FILE.write(pid)

  # Poll health; abort early if our process already died
  8.times do
    sleep 0.5
    unless (Process.kill(0, pid) rescue false)
      puts "Failed to start Milan - process exited early, check #{LOG_FILE}"
      PID_FILE.delete if PID_FILE.exist?
      return
    end
    begin
      uri = URI("http://localhost:#{MILAN_PORT}/health")
      res = Net::HTTP.start(uri.host, uri.port, open_timeout: 1, read_timeout: 1) { _1.get(uri.path) }
      if res.code == "200"
        puts "Milan started (PID #{pid})"
        return
      end
    rescue
      # not yet ready, keep waiting
    end
  end

  if running?
    puts "Milan started (PID #{pid}) — port not yet responding"
  else
    puts "Failed to start Milan - check #{LOG_FILE}"
    PID_FILE.delete if PID_FILE.exist?
  end
end

def stop
  pid = running?

  if pid
    puts "Stopping Milan (PID #{pid})..."
    Process.kill("TERM", pid) rescue nil
    5.times { sleep 1; break unless running? }
    Process.kill("KILL", pid) rescue nil
    PID_FILE.delete if PID_FILE.exist?
  else
    puts "Milan not running (no PID file)"
    PID_FILE.delete if PID_FILE.exist?
  end

  # Safety net: clear anything still on the port
  unless port_free?
    puts "Clearing stale process on port #{MILAN_PORT}..."
    clear_port
  end

  puts "Stopped."
end

def status
  unless (pid = running?)
    puts "Milan not running"
    return
  end

  puts "Milan running (PID #{pid})"

  begin
    uri = URI("http://localhost:8080/")
    # Quick internal healthcheck
    response = Net::HTTP.start(uri.host, uri.port, open_timeout: 1, read_timeout: 1) { _1.get(uri.request_uri) }

    data = JSON.parse(response.body, symbolize_names: true)
    puts "Uptime: #{data[:uptime_seconds]}s | Requests: #{data[:requests]} | Scripts: #{data[:scripts_run]}"
  rescue StandardError
    puts "Service reachable, but port 8080 does not respond with valid JSON."
  end
end

# CLI
command = ARGV.shift
@dylan_url = "" if ARGV.include?("--standalone")

case command
when "start"   then start
when "stop"    then stop
when "restart" then stop; start
when "status"  then status
when "log"     then exec "tail -f #{LOG_FILE}"
when "whoami"  then check_identity
else
  puts "Usage: #{$PROGRAM_NAME} {start|stop|restart|status|log|whoami} [--standalone]"
end
